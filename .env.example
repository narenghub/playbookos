# ── Abiozen PlaybookOS — Environment Configuration ──────────────────────────
# Copy this file to .env and fill in your values before starting the server

# Server
PORT=3000
NODE_ENV=production

# Security — generate a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_32_CHARS_MIN
ADMIN_EMAIL=naresh@abiozen.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Anthropic Claude API
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# GitHub Integration
# Create at: https://github.com/settings/tokens
# Scopes needed: repo, read:org, read:user
GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_TOKEN
GITHUB_ORG=abiozen

# Email (Nodemailer) — use Gmail App Password or SMTP relay
# Gmail: enable 2FA → App Passwords → generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=naresh@abiozen.com
SMTP_PASS=REPLACE_WITH_APP_PASSWORD
EMAIL_FROM=PlaybookOS <naresh@abiozen.com>

# Company defaults
COMPANY_NAME=Abiozen LLC
ANNUAL_TARGET=10000000
LAUNCH_DATE=2026-05-01
YEAR_END=2026-12-31
