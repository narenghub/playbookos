# PlaybookOS — environment configuration
# Copy this file to .env and fill in real values, then run `node server.js`.

# ── Server ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
BASE_URL=http://localhost:3000

# ── Database ───────────────────────────────────────────────────────
# Local Postgres example:
#   postgresql://user:password@localhost:5432/playbookos
# On Railway, set this as a reference variable: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/playbookos

# ── Security ───────────────────────────────────────────────────────
# Generate each value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_32_BYTE_HEX_SECRET
TRIGGERS_SECRET=REPLACE_WITH_32_BYTE_HEX_SECRET
PLAYBOOKOS_WEBHOOK_SECRET=REPLACE_WITH_32_BYTE_HEX_SECRET
ENGAGEMENT_SECRET=REPLACE_WITH_32_BYTE_HEX_SECRET

# ── Admin bootstrap (used on first DB init only) ───────────────────
# The seeded admin user gets role='admin'. Other team members are invited
# from the Team page; available roles come from src/lib/roles.js BUILT_IN_ROLES
# plus the custom_roles table. See README "Role taxonomy" section.
ADMIN_EMAIL=naren@abiozen.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Anthropic Claude ───────────────────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# ── Resend (transactional email) ───────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_REPLACE_WITH_YOUR_KEY

# ── Apollo.io (sales outreach) ─────────────────────────────────────
# https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=REPLACE_WITH_YOUR_APOLLO_KEY

# ── GitHub (developer activity sync) ───────────────────────────────
# https://github.com/settings/tokens — required scopes: repo, read:org, read:user
GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_TOKEN
GITHUB_ORG=abiozen

# ── Algolia ────────────────────────────────────────────────────────
# One purpose-scoped key per operation class (least privilege). Each scoped
# key falls back to ALGOLIA_API_KEY when left blank, so a single-key setup
# still works — but provisioning dedicated keys is recommended for production.
#
# ALGOLIA_APP_ID — the Algolia application ID, shared by every operation.
ALGOLIA_APP_ID=
# ALGOLIA_API_KEY — WRITE key. Batch indexing / catalog sync (POST
# /api/algolia/sync, /api/algolia/sync-abiozen, scripts/sync-algolia.js).
# Needs the `addObject` ACL. Also the fallback for the three scoped keys below.
ALGOLIA_API_KEY=
# ALGOLIA_SEARCH_KEY — used by growth-agent.js (and, through it, seo-agent.js
# zero-result tracking) for the search-term endpoints: /2/searches and
# /2/searches/noResults — top searches and no-result searches. These are
# Algolia Analytics API endpoints, so this key must carry the `analytics` ACL.
# Falls back to ALGOLIA_API_KEY when unset.
ALGOLIA_SEARCH_KEY=
# ALGOLIA_ANALYTICS_KEY — used by growth-agent.js for the click-through-rate
# and conversion-rate endpoints (/2/clicks, /2/conversions). Needs the
# `analytics` ACL. Falls back to ALGOLIA_API_KEY when unset.
ALGOLIA_ANALYTICS_KEY=
# ALGOLIA_RECOMMENDATION_KEY — RECOMMEND key. Algolia Recommend API. Needs the
# `recommendation` ACL. Stub only — no Recommend calls are wired yet.
ALGOLIA_RECOMMENDATION_KEY=
# ALGOLIA_INDEX_NAME — unified catalog index. Code falls back to
# 'abiozen_products' if this is unset.
ALGOLIA_INDEX_NAME=abiozen_products

# ── Google Search Console (OAuth 2.0 user credentials) ────────────────────────
# The GSC searchAnalytics API requires OAuth — API keys are rejected, and
# service accounts can only be used if added as a property user. This setup
# uses an OAuth client plus a long-lived refresh token from a Google account
# that already has access to the abiozen.com Search Console property.
# growth-agent.js exchanges the refresh token for a short-lived access token
# on each run.
#
# Set-up:
#   1. Google Cloud Console -> APIs & Services -> Credentials -> Create
#      Credentials -> OAuth client ID. Add
#      https://developers.google.com/oauthplayground as an authorized
#      redirect URI. Copy the client ID and client secret below.
#   2. Enable the Search Console API for that project.
#   3. Mint a refresh token once via the OAuth 2.0 Playground
#      (https://developers.google.com/oauthplayground/) using your own OAuth
#      credentials and the scope:
#        https://www.googleapis.com/auth/webmasters.readonly
#      Sign in with the Google account that has Search Console access.
# Leave GOOGLE_REFRESH_TOKEN empty to skip GSC and rely on Algolia alone.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Optional: override the GSC site URL. Default: sc-domain:abiozen.com
GSC_SITE_URL=

# ── Abiozen marketplace database (for POST /api/algolia/sync-abiozen) ──────────
# Separate Postgres database from the PlaybookOS one — the Django storefront's
# production DB. Must be the PUBLIC proxy connection string: the playbookos
# service cannot reach the Abiozen DB's .railway.internal host across projects.
ABIOZEN_DATABASE_URL=postgresql://USER:PASSWORD@interchange.proxy.rlwy.net:18553/railway

# ── AI Agent System ───────────────────────────────────────────────────────────
# The AI Agent System (KPI Engine, CEO/Procurement/Sales/HR agents, orchestrator,
# approval queue, daily tasks) requires NO new environment variables. It reuses:
#   ANTHROPIC_API_KEY — agent reasoning / Claude calls
#   RESEND_API_KEY    — CEO and HR briefing emails
#   DATABASE_URL      — kpi_hierarchy, agent_activity_log, approval_queue,
#                       daily_tasks and agent_messages tables (auto-migrated)
# Agent crons run on America/Chicago (CST) time. Per-user briefing routing uses
# the users.timezone column (default 'America/Chicago').

# ── OpenAI (DALL-E 3 image generation for LinkedIn posts) ─────────────────────
# Used by src/lib/agents/linkedin-agent.js generatePostImage() to generate
# 1024x1024 background images for LinkedIn posts (typical cost ~$0.04 per
# image). Without this var the "Regenerate image" button skips with a 503;
# the weekly campaign still runs (with PubChem structure images, which are free
# and need no key).
OPENAI_API_KEY=

# ── LinkedIn AI Content Engine ────────────────────────────────────────────────
# Used by src/lib/agents/linkedin-agent.js to post to the Abiozen company page
# via the LinkedIn UGC API (https://api.linkedin.com/v2/ugcPosts). Without
# these vars the Monday 10am scheduler still drafts posts into
# linkedin_content_queue, but POST /api/linkedin/publish/:id skips with a 503.
#
# Set-up:
#   1. https://www.linkedin.com/developers -> create an app and request the
#      "Share on LinkedIn" and "Marketing Developer Platform" products.
#   2. Mint a long-lived access token via the 3-legged OAuth flow.
#   3. LINKEDIN_ORGANIZATION_ID is the numeric ID at the end of
#      linkedin.com/company/{id}/admin/ — agent prepends urn:li:organization:
#      automatically if you supply just the number.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_ORGANIZATION_ID is kept for forward compatibility — posts will
# switch to urn:li:organization:<id> once the w_organization_social scope is
# granted on the access token. Until then publishPost uses the member URN.
LINKEDIN_ORGANIZATION_ID=
# LINKEDIN_PERSON_ID — the LinkedIn member ID (the `sub` value from OIDC
# /v2/userinfo) used as the author URN for personal-profile posts. If left
# empty, publishPost calls /v2/userinfo with LINKEDIN_ACCESS_TOKEN on every
# publish to resolve it; setting it here skips that roundtrip. Accepts either
# the bare ID or "urn:li:person:<id>".
LINKEDIN_PERSON_ID=
# LINKEDIN_POST_AS_ORG — set to "true" to publish as the company page
# (urn:li:organization:<LINKEDIN_ORGANIZATION_ID>) instead of the personal
# profile. Requires the token to carry w_organization_social scope, which
# becomes available once the LinkedIn Community Management API approval
# lands. Default (unset or any other value) is personal-profile posting.
LINKEDIN_POST_AS_ORG=

# ── Twilio WhatsApp (Performance Accountability escalations) ──────────────────
# Used by src/lib/whatsapp.js to send escalation reminders/warnings to users
# whose performance score has dropped (Levels 1-4 of runEscalationCheck).
# Skips gracefully when any of these three are unset — escalations still send
# email, just not WhatsApp. Set users.whatsapp_number per user to receive.
#
# Set-up: console.twilio.com -> get SID and Auth Token. Then enable WhatsApp
# Sandbox (or buy a number) and set the From value to the sandbox/your number.
# TWILIO_WHATSAPP_FROM accepts either "+14155238886" or "whatsapp:+14155238886".
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
