# PlaybookOS — environment configuration
# Copy this file to .env and fill in real values, then run `node server.js`.

# ── Server ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
BASE_URL=http://localhost:3000

# ── Database ───────────────────────────────────────────────────────
# Local Postgres example:
#   postgresql://user:password@localhost:5432/playbookos
# On Railway, set this as a reference variable: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/playbookos

# ── Security ───────────────────────────────────────────────────────
# Generate each value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_32_BYTE_HEX_SECRET
TRIGGERS_SECRET=REPLACE_WITH_32_BYTE_HEX_SECRET
PLAYBOOKOS_WEBHOOK_SECRET=REPLACE_WITH_32_BYTE_HEX_SECRET

# ── Admin bootstrap (used on first DB init only) ───────────────────
ADMIN_EMAIL=naren@abiozen.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Anthropic Claude ───────────────────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# ── Resend (transactional email) ───────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_REPLACE_WITH_YOUR_KEY

# ── Apollo.io (sales outreach) ─────────────────────────────────────
# https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=REPLACE_WITH_YOUR_APOLLO_KEY

# ── GitHub (developer activity sync) ───────────────────────────────
# https://github.com/settings/tokens — required scopes: repo, read:org, read:user
GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_TOKEN
GITHUB_ORG=abiozen

# ── Growth Intelligence (Algolia + Google Search Console) ──────────
# Algolia Analytics API — used by src/lib/agents/growth-agent.js to read
# top searches with no results, top queries, click-through rate, and conversion
# rate against the marketplace index. The API key here must have analytics
# read access (admin key or a dedicated analytics-scoped key).
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
ALGOLIA_INDEX_NAME=abiozen_products

# Google Search Console — used to identify queries where the site appears
# in Google results but has low CTR. GSC requires OAuth (not a static API key),
# so this variable is a short-lived bearer token. Either refresh it externally
# before the Monday 8am cron, or replace with a proper OAuth/service-account
# refresh flow. Leave empty to skip GSC and rely on Algolia alone.
GOOGLE_SEARCH_CONSOLE_KEY=
# Optional: override the GSC site URL. Default: sc-domain:abiozen.com
GSC_SITE_URL=
